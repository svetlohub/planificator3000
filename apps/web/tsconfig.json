{
  "extends": "../../packages/config/typescript/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@planner3000/shared": ["../../packages/shared/src/index.ts"],
      "@planner3000/ui": ["../../packages/ui/src/index.ts"],
      "@planner3000/ui/*": ["../../packages/ui/src/*"]
